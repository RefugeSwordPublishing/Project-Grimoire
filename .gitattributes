# Force LF for text files so Windows checkouts stop churning CRLF on every touch.
# This repo is design docs + Supabase SQL/TS; the Unity project (with its binaries)
# lives in the ProjectGrimoire submodule and has its own attributes.
*.md    text eol=lf
*.sql   text eol=lf
*.ts    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
